import React from 'react';

export interface CartBadgeProps {
  count?: number;
  onClick?: () => void;
}

export const CartBadge: React.FC<CartBadgeProps> = ({ count = 0, onClick }) => {
  return (
    <div 
      onClick={onClick}
      className="relative group cursor-pointer active:scale-95 transition-all"
    >
      <div className="bg-zinc-100 dark:bg-zinc-800 p-2.5 rounded-full hover:bg-zinc-200 transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="text-zinc-600 dark:text-zinc-300"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
      </div>
      
      {count > 0 && (
        <div className="absolute -top-1.5 -right-1.5 bg-primary text-white text-[10px] font-black h-5 w-5 rounded-full flex items-center justify-center border-2 border-white shadow-lg animate-in zoom-in-50 duration-300">
           {count}
        </div>
      )}
      
      <div className="absolute -bottom-8 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity bg-zinc-900 text-white text-[9px] font-bold px-2 py-1 rounded pointer-events-none whitespace-nowrap z-50">
         {count} items in bag
      </div>
    </div>
  );
};

(CartBadge as any).meta = {
  name: "CartBadge",
  version: "1.0.0",
  migrations: {},
  type: "free",
  description: "UI Base para el contador de carrito.",
  props: {
    count: { type: "number", defaultValue: 0 }
  }
};
