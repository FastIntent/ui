import React, { forwardRef } from "react";
import { cn } from "../../utils/cn";

export interface FooterProps {
  className?: string;
  style?: React.CSSProperties;
  content?: string;
  theme?: "light" | "dark";
}

export const Footer = forwardRef<HTMLDivElement, FooterProps>(
  ({ className, style, content, theme, ...props }, ref) => {
    const isDark = theme === "dark";
    
    return (
      <div 
        ref={ref}
        className={cn(
           "w-full px-8 py-6 flex flex-col items-center justify-center gap-2 border-t text-sm font-medium transition-colors", 
           isDark ? "bg-zinc-900 border-zinc-800 text-zinc-300" : "bg-white border-zinc-200 text-zinc-600",
           className
        )}
        style={style}
        {...props}
      >
         <div className="flex items-center gap-4">
            <span className={cn(isDark ? "text-zinc-500" : "text-zinc-400", "text-[12px] md:text-[18px]")}>Remote Component v1.0</span>
         </div>
         <div>{content || "Escribe el contenido del footer en el panel derecho"}</div>
         
         <div className="mt-4 flex gap-3 text-xs opacity-70">
            <a href="#" className="hover:underline">Privacy Policy</a>
            <a href="#" className="hover:underline">Terms of Service</a>
            <a href="#" className="hover:underline">Contact</a>
         </div>
      </div>
    );
  }
);

Footer.displayName = "Footer";

(Footer as any).meta = {
  name: "Footer",
  version: "1.0.0",
  migrations: {},
  type: "free",
  description: "Pie de página corporativo con modo claro/oscuro.",
  props: {
    content: { type: "text", defaultValue: "© 2026 FastIntent - Todos los derechos reservados." },
    theme: { type: "select", options: ["light", "dark"], defaultValue: "dark" }
  }
};
